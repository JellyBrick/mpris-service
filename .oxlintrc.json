{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "import", "unicorn", "oxc", "promise", "node"],
  "jsPlugins": ["eslint-plugin-perfectionist", "@stylistic/eslint-plugin"],
  "categories": { "correctness": "error" },
  "rules": {
    "import/no-default-export": "error",
    "import/first": "error",
    "import/no-duplicates": "error",

    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-void": "error",
    "no-empty": "off",

    "typescript/consistent-type-imports": "error",
    "typescript/no-explicit-any": "error",
    "typescript/no-floating-promises": "error",
    "typescript/no-misused-promises": "error",
    "typescript/require-await": "error",

    "@stylistic/no-tabs": "error",
    "@stylistic/no-mixed-operators": "error",
    "@stylistic/arrow-parens": ["error", "always"],
    "@stylistic/quotes": [
      "error",
      "single",
      { "avoidEscape": true, "allowTemplateLiterals": "never" }
    ],
    "@stylistic/semi": ["error", "always"],
    "@stylistic/object-curly-spacing": ["error", "always"],
    "@stylistic/no-multi-spaces": "error",
    "@stylistic/comma-dangle": ["error", "always-multiline"],

    "unicorn/filename-case": ["error", { "case": "kebabCase" }],

    "perfectionist/sort-imports": [
      "warn",
      {
        "type": "natural",
        "order": "asc",
        "groups": ["builtin", "external", "internal", ["parent", "sibling", "index"], "type"],
        "newlinesBetween": 1
      }
    ]
  },
  "env": { "node": true, "builtin": true },
  "ignorePatterns": ["dist/**", "node_modules/**", "examples/**"],
  "overrides": [
    {
      "files": ["*.config.ts", "test/**", "src/index.ts"],
      "rules": { "import/no-default-export": "off" }
    }
  ]
}
