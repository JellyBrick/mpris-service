{
  "name": "@jellybrick/mpris-service",
  "version": "2.2.0",
  "description": "Node.js implementation for the MPRIS D-Bus Interface Specification to create a mediaplayer service",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=12.20.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JellyBrick/mpris-service.git"
  },
  "keywords": [
    "mpris",
    "media",
    "player",
    "dbus"
  ],
  "author": "JellyBrick <shlee1503@naver.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/JellyBrick/mpris-service/issues"
  },
  "homepage": "https://github.com/JellyBrick/mpris-service",
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint --type-aware --deny-warnings src test",
    "format": "oxfmt --write src test *.config.ts",
    "format:check": "oxfmt --check src test *.config.ts",
    "test": "vitest run",
    "test:integration": "MPRIS_INTEGRATION=1 dbus-run-session -- vitest run",
    "check": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm run build && pnpm run test"
  },
  "dependencies": {
    "@jellybrick/dbus-next": "^0.11.1",
    "fast-equals": "^6.0.0"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc/core": "^1.15.41",
    "@types/node": "^25.9.3",
    "eslint-plugin-perfectionist": "^5.9.1",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.9"
  }
}
